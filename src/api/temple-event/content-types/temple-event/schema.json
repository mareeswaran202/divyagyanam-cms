{
  "kind": "collectionType",
  "collectionName": "temple_events",
  "info": {
    "singularName": "temple-event",
    "pluralName": "temple-events",
    "displayName": "Temple Event"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "EventName": {
      "type": "string"
    },
    "Slug": {
      "type": "uid"
    },
    "EventDate": {
      "type": "date"
    },
    "EndDate": {
      "type": "date"
    },
    "temples": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::templecollection.templecollection",
      "inversedBy": "temple_events"
    },
    "EventType": {
      "type": "enumeration",
      "enum": [
        "Festival",
        "Pooja",
        "Abhishekam",
        "Krishna Janmashtami",
        "Ekadashi",
        "Pradosham",
        "Amavasya",
        "Pournami",
        "Annadanam",
        "Brahmotsavam",
        "Kumbabishekam",
        "Special Event",
        "Live Darshan"
      ]
    },
    "Description": {
      "type": "blocks"
    },
    "Banner": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Featured": {
      "type": "boolean"
    },
    "IsRecurring": {
      "type": "boolean"
    }
  }
}
