{
  "kind": "collectionType",
  "collectionName": "templecollections",
  "info": {
    "singularName": "templecollection",
    "pluralName": "templecollections",
    "displayName": "Templecollection"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "TempleName": {
      "type": "string",
      "required": true
    },
    "Slug": {
      "type": "uid",
      "targetField": "TempleName",
      "required": true
    },
    "ShortDescription": {
      "type": "string"
    },
    "TempleImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Featured": {
      "type": "boolean",
      "default": true
    },
    "State": {
      "type": "string"
    },
    "District": {
      "type": "string"
    },
    "Deity": {
      "type": "string"
    },
    "Location": {
      "type": "string"
    },
    "DescriptionRich": {
      "type": "blocks"
    },
    "temple_event": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::temple-event.temple-event",
      "inversedBy": "Temple"
    }
  }
}
